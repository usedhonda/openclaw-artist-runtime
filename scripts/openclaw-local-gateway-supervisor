#!/usr/bin/env bash
# Keep-alive supervisor for the local artist-runtime gateway.
# Spawned by `openclaw-local-gateway start`. Loops `gateway run` so
# unexpected exits/crashes are auto-restarted with backoff.

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "${script_dir}/openclaw-local-env.sh"
# env.sh enables `set -euo pipefail`; the supervisor must keep running after
# the child gateway crashes (wait returns 137 etc.), so we relax those.
set +e
set +u
set +o pipefail

supervisor_log="${OPENCLAW_LOCAL_LOGS}/gateway.supervisor.log"
watchdog_log="${OPENCLAW_LOCAL_LOGS}/telegram-watchdog.log"
watchdog_flag="${OPENCLAW_LOCAL_WORKSPACE}/runtime/telegram-watchdog-fired-at.txt"
mkdir -p "${OPENCLAW_LOCAL_LOGS}"
mkdir -p "${OPENCLAW_LOCAL_WORKSPACE}/runtime"

restart_delay_seconds="${OPENCLAW_LOCAL_GATEWAY_RESTART_DELAY:-3}"
watchdog_enabled="${OPENCLAW_TELEGRAM_WATCHDOG_ENABLED:-0}"
watchdog_interval="${OPENCLAW_TELEGRAM_WATCHDOG_INTERVAL:-30}"
watchdog_tail_lines="${OPENCLAW_TELEGRAM_WATCHDOG_TAIL_LINES:-300}"
watchdog_threshold="${OPENCLAW_TELEGRAM_WATCHDOG_THRESHOLD:-10}"
watchdog_grace_seconds="${OPENCLAW_TELEGRAM_WATCHDOG_GRACE_SECONDS:-90}"
supervisor_heartbeat_interval="${OPENCLAW_SUPERVISOR_HEARTBEAT_INTERVAL:-15}"
crash_tail_lines="${OPENCLAW_SUPERVISOR_CRASH_TAIL_LINES:-400}"
supervisor_started_ms="$(node -e 'console.log(Date.now())' 2>/dev/null || date +%s000)"
child=""
watchdog_pid=""
heartbeat_pid=""

log_line() {
  printf '[supervisor %s] %s\n' "$(date '+%Y-%m-%dT%H:%M:%S')" "$1" >>"${supervisor_log}"
}

watchdog_log_line() {
  printf '[watchdog %s] %s\n' "$(date '+%Y-%m-%dT%H:%M:%S')" "$1" >>"${watchdog_log}"
}

now_ms() {
  node -e 'console.log(Date.now())' 2>/dev/null || date +%s000
}

write_supervisor_heartbeat() {
  node "${script_dir}/openclaw-supervisor-health.mjs" heartbeat \
    --workspace "${OPENCLAW_LOCAL_WORKSPACE}" \
    --pid "$$" \
    --started-at-ms "${supervisor_started_ms}" >/dev/null 2>&1 \
    || log_line "supervisor heartbeat write failed"
}

supervisor_heartbeat_loop() {
  while true; do
    write_supervisor_heartbeat
    sleep "${supervisor_heartbeat_interval}"
  done
}

capture_gateway_exit_evidence() {
  local target_pid="$1"
  local target_rc="$2"
  local target_started_ms="$3"
  local target_exited_ms="$4"
  node "${script_dir}/openclaw-supervisor-health.mjs" crash-evidence \
    --workspace "${OPENCLAW_LOCAL_WORKSPACE}" \
    --pid "${target_pid}" \
    --rc "${target_rc}" \
    --started-at-ms "${target_started_ms}" \
    --exited-at-ms "${target_exited_ms}" \
    --log "${OPENCLAW_LOCAL_GATEWAY_LOG}" \
    --tail-lines "${crash_tail_lines}" >>"${supervisor_log}" 2>&1 \
    || log_line "gateway crash evidence capture failed pid=${target_pid} rc=${target_rc}"
}

watchdog_loop() {
  local target_pid="$1"
  if [[ "${watchdog_enabled}" != "1" && "${watchdog_enabled}" != "on" && "${watchdog_enabled}" != "true" ]]; then
    watchdog_log_line "disabled for target_pid=${target_pid}; OPENCLAW_TELEGRAM_WATCHDOG_ENABLED=${watchdog_enabled}"
    return
  fi

  watchdog_log_line "started target_pid=${target_pid} interval=${watchdog_interval}s tail=${watchdog_tail_lines} threshold=${watchdog_threshold} grace=${watchdog_grace_seconds}s"

  sleep "${watchdog_grace_seconds}"

  while kill -0 "${target_pid}" 2>/dev/null; do
    sleep "${watchdog_interval}"
    if [[ ! -f "${OPENCLAW_LOCAL_GATEWAY_LOG}" ]]; then
      continue
    fi
    local recent_count
    # v10.26.2: match the log format actually emitted by the gateway. The
    # Telegram polling client logs prefixed lines like `[telegram] fetch
    # fallback ... codes=ENETUNREACH` and bare `Error: connect ENETUNREACH ...`
    # rows. The previous `telegram/network` prefix never matched, so the
    # watchdog stayed silent while polling died.
    recent_count=$(tail -"${watchdog_tail_lines}" "${OPENCLAW_LOCAL_GATEWAY_LOG}" 2>/dev/null \
      | grep -cE '(\[telegram\].*(ENETUNREACH|UND_ERR_CONNECT_TIMEOUT)|Error: connect ENETUNREACH|Error: connect UND_ERR_CONNECT_TIMEOUT)' 2>/dev/null)
    recent_count="${recent_count:-0}"
    if [[ "${recent_count}" -ge "${watchdog_threshold}" ]]; then
      watchdog_log_line "telegram polling stuck (errors=${recent_count} in last ${watchdog_tail_lines} lines), killing child pid=${target_pid}"
      mkdir -p "$(dirname "${watchdog_flag}")"
      date +%s >"${watchdog_flag}"
      kill -TERM "${target_pid}" 2>/dev/null
      return
    fi
  done
  watchdog_log_line "target_pid=${target_pid} exited; watchdog stopping"
}

handle_term() {
  log_line "received signal; shutting down"
  if [[ -n "${watchdog_pid}" ]]; then
    kill "${watchdog_pid}" 2>/dev/null
  fi
  if [[ -n "${heartbeat_pid}" ]]; then
    kill "${heartbeat_pid}" 2>/dev/null
  fi
  if [[ -n "${child}" ]]; then
    kill "${child}" 2>/dev/null
  fi
  exit 0
}
trap handle_term TERM INT QUIT
trap 'log_line "received SIGHUP; ignoring"' HUP

log_line "started (pid $$)"
supervisor_heartbeat_loop &
heartbeat_pid=$!

while true; do
  child_started_ms="$(now_ms)"
  (
    trap '' HUP
    exec "${script_dir}/openclaw-local" gateway run \
      --allow-unconfigured \
      --bind loopback \
      --auth none \
      --port "${OPENCLAW_LOCAL_GATEWAY_PORT}" \
      "$@"
  ) >>"${OPENCLAW_LOCAL_GATEWAY_LOG}" 2>&1 &
  child=$!
  log_line "spawned gateway pid=${child}"

  watchdog_loop "${child}" &
  watchdog_pid=$!

  wait "${child}"
  rc=$?
  child_exited_ms="$(now_ms)"

  if [[ -n "${watchdog_pid}" ]]; then
    kill "${watchdog_pid}" 2>/dev/null
    wait "${watchdog_pid}" 2>/dev/null
    watchdog_pid=""
  fi

  capture_gateway_exit_evidence "${child}" "${rc}" "${child_started_ms}" "${child_exited_ms}"
  log_line "gateway exited pid=${child} rc=${rc}; restart in ${restart_delay_seconds}s"
  child=""
  sleep "${restart_delay_seconds}"
done
